# ---------------------------------------------------------------------------
# Rush OS environment variables
#
# 1. Copy this file to ".env.local"   ->   cp .env.example .env.local
# 2. Fill in the values below.
# 3. NEVER commit ".env.local" or real keys. This ".env.example" stays in git
#    with PLACEHOLDER values only.
# ---------------------------------------------------------------------------

# --- Supabase (from your Supabase project: Settings -> API) -----------------

# Project URL. For LOCAL development with `supabase start` this is usually:
#   http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"

# Public anon key — safe to expose to the browser. Access is limited by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service-role key — SERVER ONLY. Bypasses Row Level Security. Never expose to
# the browser, never put in a NEXT_PUBLIC_ variable, never commit it.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"
